<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/xml/file_paths.xml -->
<paths>
    <!-- Expone <cacheDir>/images/ como raíz para los Uri del provider.
         cacheDir es almacenamiento privado de la app: el sistema puede
         limpiarlo, perfecto para una foto temporal que solo mandamos a analizar. -->
    <cache-path name="camera_images" path="images/" />
</paths>